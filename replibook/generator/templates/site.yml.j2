---
# Generated by Replibook on {{ timestamp }}
# Source host: {{ hostname }} ({{ host_os }})

- name: Replibook — Reproduce {{ hostname | tojson }}
  hosts: replibook
  become: {{ "true" if use_become else "false" }}
  tasks:
{% set has_any = apt_packages or brew_packages or cask_packages or other_packages or systemd_services or systemd_user_services or brew_services or launchd_services or containers or deployments or (config and (config.users or config.groups or config.cron_jobs or config.ssh_settings or config.firewall_rules or config.mounts or config.sysctl)) %}
{% if not has_any %}
    - name: Replibook scan returned no results
      ansible.builtin.debug:
        msg: "No packages, services, containers or deployments were found on the source host."
{% endif %}

{% if apt_packages %}
    # ── Apt Packages ──────────────────────────────────────────────────────────
    - name: Install apt packages
      ansible.builtin.apt:
        name:
{% for pkg in apt_packages %}
          - {{ pkg.name | tojson }}
{% endfor %}
        state: present
        update_cache: true

{% endif %}
{% if brew_packages %}
    # ── Homebrew Formulas ─────────────────────────────────────────────────────
    - name: Install Homebrew formulas
      community.general.homebrew:
        name:
{% for pkg in brew_packages %}
          - {{ pkg.name | tojson }}
{% endfor %}
        state: present
        update_homebrew: true

{% endif %}
{% if cask_packages %}
    # ── Homebrew Casks ────────────────────────────────────────────────────────
    - name: Install Homebrew casks
      community.general.homebrew_cask:
        name:
{% for pkg in cask_packages %}
          - {{ pkg.name | tojson }}
{% endfor %}
        state: present

{% endif %}
{% if other_packages %}
    # ── Generic Linux Packages (rpm/dnf/yum/zypper/pacman) ───────────────────
    - name: Install non-apt Linux packages
      ansible.builtin.package:
        name:
{% for pkg in other_packages %}
          - {{ pkg.name | tojson }}
{% endfor %}
        state: present

{% endif %}
{% if systemd_services %}
    # ── Systemd Services ──────────────────────────────────────────────────────
{% for svc in systemd_services %}
    - name: Ensure service {{ svc.name | tojson }} is {{ svc.state }}
      ansible.builtin.service:
        name: {{ svc.name | tojson }}
        state: {{ svc.state }}
        enabled: {{ "true" if svc.enabled else "false" }}

{% endfor %}
{% endif %}
{% if systemd_user_services %}
    # ── Systemd User Services ──────────────────────────────────────────────────
{% for svc in systemd_user_services %}
    - name: Ensure user service {{ svc.name | tojson }} is {{ svc.state }}
      ansible.builtin.systemd:
        name: {{ svc.name | tojson }}
        scope: user
        state: {{ svc.state }}
        enabled: {{ "true" if svc.enabled else "false" }}

{% endfor %}
{% endif %}
{% if brew_services %}
    # ── Homebrew Services ─────────────────────────────────────────────────────
{% for svc in brew_services %}
    - name: Ensure homebrew service {{ svc.name | tojson }} is {{ svc.state }}
      community.general.homebrew_services:
        name: {{ svc.name | tojson }}
        state: {{ svc.state }}

{% endfor %}
{% endif %}
{% if launchd_services %}
    # ── Launchd Services (discovered) ──────────────────────────────────────────
    - name: Discovered launchd services (manual review)
      ansible.builtin.debug:
        msg:
{% for svc in launchd_services %}
          - {{ svc.name | tojson }}
{% endfor %}

{% endif %}
{% if containers %}
    # ── Docker Containers ──────────────────────────────────────────────────────
{% for c in containers %}
    - name: Run container {{ c.name | tojson }}
      community.docker.docker_container:
        name: {{ c.name | tojson }}
        image: {{ c.image | tojson }}
        state: started
        restart_policy: {{ c.restart_policy }}
{% if c.ports %}
        ports:
{% for p in c.ports %}
          - {{ p | tojson }}
{% endfor %}
{% endif %}
{% if c.volumes %}
        volumes:
{% for v in c.volumes %}
          - {{ v | tojson }}
{% endfor %}
{% endif %}
{% if c.env_vars %}
        env:
{% for k, v in c.env_vars.items() %}
          {{ k | tojson }}: {{ v | tojson }}
{% endfor %}
{% endif %}

{% endfor %}
{% endif %}
{% if deployments %}
    # ── Docker Compose Deployments ─────────────────────────────────────────────
{% for d in deployments %}
    - name: Deploy {{ d.name | tojson }}
      community.docker.docker_compose_v2:
        project_src: {{ d.project_src | tojson }}
        state: present

{% endfor %}
{% endif %}
{% if config and config.groups %}
    # ── System Groups ───────────────────────────────────────────────────────────
{% for group_name in config.groups %}
    - name: Ensure group {{ group_name | tojson }} exists
      ansible.builtin.group:
        name: {{ group_name | tojson }}
        state: present

{% endfor %}
{% endif %}
{% if config and config.users %}
    # ── System Users ────────────────────────────────────────────────────────────
{% for user_name in config.users %}
    - name: Ensure user {{ user_name | tojson }} exists
      ansible.builtin.user:
        name: {{ user_name | tojson }}
        state: present

{% endfor %}
{% endif %}
{% if config and config.cron_jobs %}
    # ── Cron Entries ────────────────────────────────────────────────────────────
{% for cron in config.cron_jobs %}
    - name: Recreate cron line from {{ cron.source | tojson }}
      ansible.builtin.lineinfile:
        path: {{ cron.source | tojson }}
        line: {{ cron.line | tojson }}
        create: true
        state: present

{% endfor %}
{% endif %}
{% if config and config.ssh_settings %}
    # ── SSHD Settings ───────────────────────────────────────────────────────────
{% for setting in config.ssh_settings %}
    - name: Ensure sshd {{ setting.key | tojson }} is configured
      ansible.builtin.lineinfile:
        path: /etc/ssh/sshd_config
        regexp: '^{{ setting.key }}\\s+'
        line: '{{ setting.key }} {{ setting.value }}'
        create: true
        state: present

{% endfor %}
{% endif %}
{% if config and config.sysctl %}
    # ── Sysctl Settings ─────────────────────────────────────────────────────────
{% for key, value in config.sysctl.items() %}
    - name: Ensure sysctl {{ key | tojson }} is set
      ansible.builtin.lineinfile:
        path: /etc/sysctl.conf
        regexp: '^{{ key }}\\s*='
        line: '{{ key }} = {{ value }}'
        create: true
        state: present

{% endfor %}
{% endif %}
{% if config and (config.firewall_rules or config.mounts) %}
    # ── Captured Host State (manual review) ────────────────────────────────────
    - name: Captured firewall rules and mounts
      ansible.builtin.debug:
        msg:
{% for line in config.firewall_rules %}
          - {{ ("firewall: " ~ line) | tojson }}
{% endfor %}
{% for line in config.mounts %}
          - {{ ("mount: " ~ line) | tojson }}
{% endfor %}

{% endif %}
